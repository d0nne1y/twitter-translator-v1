DISCORD_TOKEN=your_discord_bot_token
DEEPL_API_KEY=your_deepl_key_optional
TARGET_LANG=pl
IGNORE_LANGS=en,pl
DELETE_ORIGINAL_MESSAGE=true
PHOTO_UPLOAD_LIMIT_MB=8
SHOW_FOOTER=false
SHOW_LANGUAGE_BADGE=false
SHOW_STATS=true
VIDEO_LINK_MODE=player
VIDEO_LINK_STYLE=plain

# Wideo/GIF w jednym kontenerze Discord Components V2. Ustaw fx, aby wrócić do linku FxTwitter.
VIDEO_RENDER_MODE=components_v2
